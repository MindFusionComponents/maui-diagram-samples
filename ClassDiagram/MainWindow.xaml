<Window x:Class="MindFusion.Diagramming.Wpf.Samples.CS.ClassDiagram.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:diag="http://mindfusion.eu/diagramming/wpf"
	Title="MindFusion.Diagramming Sample: Class Diagram"
	Height="768" Width="1024" Icon="/App.ico">

	<Grid>
		<Grid.Resources>
			<Style TargetType="{x:Type TreeViewItem}">
				<Style.Setters>
					<Setter Property="HeaderTemplate">
						<Setter.Value>
							<DataTemplate>
								<StackPanel Orientation="Horizontal">
									<Image Source="{Binding Image}" Margin="0,0,4,0" />
									<TextBlock Text="{Binding Name}" />
								</StackPanel>
							</DataTemplate>
						</Setter.Value>
					</Setter>
				</Style.Setters>
			</Style>
		</Grid.Resources>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition />
			<RowDefinition />
		</Grid.RowDefinitions>

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="200" />
			<ColumnDefinition />
		</Grid.ColumnDefinitions>

		<diag:DiagramView
			x:Name="diagramView"
			Grid.Row="1"
			Grid.Column="2"
			Grid.RowSpan="2">

			<diag:Diagram
				Name="diagram"
				DrawNode="diagram_DrawNode"
				NodeClicked="diagram_NodeClicked"
				LinkHeadShape="Triangle"
				LinkHeadShapeSize="6" />

		</diag:DiagramView>

		<diag:Overview
			Name="overview"
			ScaleMode="FitAll"
			Margin="0,0,4,0"
			Grid.Row="2" />

		<TreeView Grid.Row="1" Name="treeView1" Margin="0,0,4,4" />
		<Menu Grid.ColumnSpan="2" Name="menu">
			<MenuItem Header="_File" Name="menuFile">
				<MenuItem Header="_Load Assembly" Name="menuLoadAssembly" Click="menuLoadAssembly_Click" />
				<MenuItem Header="E_xit" Name="menuExit" Click="menuExit_Click" />
			</MenuItem>
		</Menu>
		<GridSplitter Grid.Column="0" Grid.Row="1" Grid.RowSpan="2" Width="4" />
	</Grid>

</Window>
