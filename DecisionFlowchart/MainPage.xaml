<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:diag="http://mindfusion.eu/diagramming/maui"
             x:Class="DecisionFlowchart.MainPage"
             BackgroundColor="#F8FAFC">
	<Grid RowDefinitions="Auto, *">
		<!-- Modern App Header -->
		<VerticalStackLayout Grid.Row="0" Padding="16, 16, 16, 8" HorizontalOptions="Center">
			<Label Text="DECISION FLOWCHART" 
			       FontSize="11" 
			       FontAttributes="Bold" 
			       TextColor="#0EA5E9" 
			       HorizontalOptions="Center" 
			       CharacterSpacing="1.5" />
			<Label Text="Should I Enroll at a University?" 
			       FontSize="20" 
			       FontFamily="OpenSansSemibold" 
			       TextColor="#0F172A" 
			       HorizontalOptions="Center" 
			       Margin="0,2,0,0" />
		</VerticalStackLayout>

		<!-- Zoomable & Pannable Diagram Canvas -->
		<diag:DiagramView Grid.Row="1" x:Name="diagramView" />
	</Grid>
</ContentPage>
