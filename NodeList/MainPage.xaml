<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:diag="http://mindfusion.eu/diagramming/maui"
             x:Class="NodeList.MainPage">

	<Grid
		RowDefinitions="*,Auto"
		ColumnDefinitions="*,120">

		<diag:DiagramView
			x:Name="diagramView" />

		<diag:NodeListView
			x:Name="nodeListView"
			Grid.Column="1"
			Grid.RowSpan="2" />

		<Label Grid.Row="1">
			Drag from the list view to diaram canvas to create a new instance of the dragged node.
		</Label>

	</Grid>

</ContentPage>
