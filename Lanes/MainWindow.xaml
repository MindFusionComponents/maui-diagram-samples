<Window x:Class="MindFusion.Diagramming.Wpf.Samples.CS.Lanes.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:diag="http://mindfusion.eu/diagramming/wpf"
	Title="MindFusion.Diagramming Sample: Lanes"
	Height="768" Width="1024" Icon="/App.ico">

	<Grid>
        <diag:DiagramView x:Name="diagramView">
			<diag:Diagram 
                x:Name="diagram" 
                BackBrush="#FFF0F0FA" 
                VerticalAlignment="Top" 
                HorizontalAlignment="Left"
                HitTestAdjustmentHandles="diagram_HitTestAdjustmentHandles"
                NodeCreated="diagram_NodeCreated"
                NodeCreating="diagram_NodeCreating"
                SelectionChanged="diagram_SelectionChanged"
                NodeModifying="diagram_NodeModifying"
				SelectionModifying="diagram_SelectionModifying"
                LinkCreated="diagram_LinkCreated"
                NodeModified="diagram_NodeModified"
                LinkHeadShapeSize="6"
                LinkHeadShape="Triangle"
                LinkBrush="Black"
                DefaultShape="Rectangle"
                AllowSelfLoops="False"
                SnapToAnchor="OnCreateOrModify"
                LinkCascadeOrientation="Horizontal"
                LinkSegments="2"
                LinkShape="Cascading">
			</diag:Diagram>
		</diag:DiagramView>
	</Grid>

</Window>