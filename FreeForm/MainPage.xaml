<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:diag="http://mindfusion.eu/diagramming/maui"
             x:Class="FreeForm.MainPage">

	<Grid RowDefinitions="*, Auto">

		<diag:DiagramView 
			x:Name="diagramView"
			Behavior="DrawFreeShapes" />

		<Label Grid.Row="1" >
			Draw ellipse, rectangle or diamond shape outlines to automatically convert them to ShapeNode objects.
		</Label>

	</Grid>

</ContentPage>
